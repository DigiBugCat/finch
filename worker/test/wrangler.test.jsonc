{
  // Dedicated wrangler config for the vitest pool-workers runtime. It mirrors the
  // top-level durable_objects + SQLite migrations from ../wrangler.jsonc so the
  // tests can instantiate the REAL BoxDO / TenantDO / RouterDO classes
  // against an isolated in-memory Miniflare. Secrets (FINCH_SERVICE_SECRET,
  // TICKET_SECRET) and DEV vars are injected per-test via `vars` here — they are
  // test-only fixtures, never the prod values. No routes / no workers.dev.
  "name": "finch-test",
  "main": "../src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "FINCH_SERVICE_SECRET": "test-service-secret",
    "TICKET_SECRET": "test-ticket-secret",
    // SEPARATE login-wall session signer (kind:"session" cookies). Distinct from
    // TICKET_SECRET so the tests exercise the real two-secret split.
    "SESSION_SECRET": "test-session-secret",
    "DEFAULT_TENANT": "dev-tenant",
    "DEV": "1",
    // The login wall 302s here; a stable test value lets the e2e assert the
    // Location host without depending on prod config.
    "WEB_URL": "https://web.test",
    "AVIARY_VERIFICATION_ORIGINS": "https://web.test",
    "VANITY_SUFFIXES": "aviary.run",
    "VANITY_TENANT": "tenant_vanity",
    "BYO_CNAME_TARGET": "finchmcp.com",
    // Activates the OAuth plane (RFC 9728 discovery, AS-metadata proxy, 401
    // scope hint, Clerk-bearer verification) so tests can assert its shapes.
    // A fake origin — upstream fetches to it are stubbed with fetchMock.
    "CLERK_ISSUER": "https://clerk.test"
  },
  "durable_objects": {
    "bindings": [
      { "name": "BOX", "class_name": "BoxDO" },
      { "name": "TENANT", "class_name": "TenantDO" },
      { "name": "ROUTER", "class_name": "RouterDO" },
      { "name": "AVIARY_ENROLLMENT", "class_name": "AviaryEnrollmentDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ApplianceDO"] },
    { "tag": "v2", "new_sqlite_classes": ["TenantDO"] },
    { "tag": "v3", "new_sqlite_classes": ["RouterDO"] },
    { "tag": "v4", "renamed_classes": [{ "from": "ApplianceDO", "to": "BoxDO" }] },
    { "tag": "v5", "new_sqlite_classes": ["AviaryEnrollmentDO"] }
  ]
}
