{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "finch",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // No top-level `vars`. DEFAULT_TENANT is DEV-ONLY (see [env.dev]) — it must
  // never ship to prod, where tenantFromHost/resolveTenant fail closed (404).
  // Secrets (FINCH_SERVICE_SECRET, TICKET_SECRET) come from `.dev.vars` in dev
  // and `wrangler secret put … --env <env>` in prod — never checked in here.
  //
  // NOTE: wrangler does NOT inherit top-level durable_objects / migrations /
  // vars into named environments, so each env below repeats durable_objects +
  // migrations. The class definitions are identical, but DO ids are name-scoped
  // per Worker — so finch-dev and finch-prod get fully separate
  // BoxDO/TenantDO/RouterDO namespaces. A dev deploy can never read or
  // mutate prod tenant registries, keys, or ACLs.
  "durable_objects": {
    "bindings": [
      { "name": "BOX", "class_name": "BoxDO" },
      { "name": "TENANT", "class_name": "TenantDO" },
      { "name": "ROUTER", "class_name": "RouterDO" }
    ]
  },
  // Cloudflare Rate Limiting (unsafe.bindings) is defined PER-ENV below — wrangler
  // does not inherit top-level `unsafe` into named environments (same as
  // durable_objects / migrations / vars), and deploys always target --env. See
  // each env's "unsafe" block. RELAY_LIMIT gates the MCP relay per-(tenant,IP)
  // BEFORE any DO round-trip (login-wall probe + checkKey); its 600/60s budget
  // covers a single web page's sub-resource burst (one HTML hit fans out to many
  // asset requests sharing the bucket). JOIN_LIMIT gates /join per-IP. The code
  // fails OPEN when the binding is absent (dev/test). (security M5)
  "migrations": [
    {
      // SQLite-backed DOs — required for the free tier and the modern DO API.
      "tag": "v1",
      "new_sqlite_classes": ["ApplianceDO"]
    },
    {
      // TenantDO — per-tenant control-plane state, also SQLite-backed.
      "tag": "v2",
      "new_sqlite_classes": ["TenantDO"]
    },
    {
      // RouterDO — singleton slug→tenantId index for the relay plane.
      "tag": "v3",
      "new_sqlite_classes": ["RouterDO"]
    },
    {
      "tag": "v4",
      "renamed_classes": [{ "from": "ApplianceDO", "to": "BoxDO" }]
    }
  ],

  "env": {
    // ---- dev: workers.dev, DEFAULT_TENANT fallback enabled (DEV=1) ----
    "dev": {
      "name": "finch-dev",
      "workers_dev": true,
      "observability": { "enabled": true },
      // DEFAULT_TENANT lives ONLY here (and in .dev.vars for `wrangler dev`).
      // DEV=1 gates the dev-only tenant fallback in resolveTenant.
      "vars": {
        "DEFAULT_TENANT": "dev-tenant",
        "DEV": "1"
      },
      "durable_objects": {
        "bindings": [
          { "name": "BOX", "class_name": "BoxDO" },
          { "name": "TENANT", "class_name": "TenantDO" },
          { "name": "ROUTER", "class_name": "RouterDO" }
        ]
      },
      // unsafe is NOT inherited into named envs — repeat it per env (see CLAUDE.md).
      "unsafe": {
        "bindings": [
          {
            "name": "RELAY_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1001",
            "simple": { "limit": 600, "period": 60 }
          },
          {
            "name": "JOIN_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1002",
            "simple": { "limit": 10, "period": 60 }
          }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["ApplianceDO"] },
        { "tag": "v2", "new_sqlite_classes": ["TenantDO"] },
        { "tag": "v3", "new_sqlite_classes": ["RouterDO"] },
        { "tag": "v4", "renamed_classes": [{ "from": "ApplianceDO", "to": "BoxDO" }] }
      ]
    },

    // ---- staging: workers.dev, dev-shaped tenant fallback, OWN namespaces ----
    // Internet-reachable pre-prod that CI auto-deploys on every push to main.
    // Like dev it carries DEFAULT_TENANT/DEV (so it's usable on a workers.dev
    // origin with no registered <slug>.finchmcp.com), but it is a fully separate
    // Worker (finch-staging) with its OWN BoxDO/TenantDO/RouterDO
    // namespaces and its OWN secrets — it can never read or mutate prod state.
    // True wildcard host routing is exercised only in production (validated by
    // the prod smoke test); to upgrade staging to staging.finchmcp.com later,
    // drop DEFAULT_TENANT/DEV, set workers_dev:false, and add a route + cert.
    "staging": {
      "name": "finch-staging",
      "workers_dev": true,
      "observability": { "enabled": true },
      "vars": {
        // Staging has one workers.dev host (no per-tenant subdomains), so the
        // relay plane resolves every request to this single dev-fallback tenant.
        // Point it at the operator's own tenant so a `finch login`-enrolled box
        // actually relays + shows up chirping in their dashboard on staging.
        // (Prod has none of this — it fails closed and routes by slug subdomain.)
        "DEFAULT_TENANT": "user_3F74fiQzwjM6UPfl9axNpA1jgyQ",
        "CLERK_ISSUER": "https://strong-terrier-95.clerk.accounts.dev",
        "DEV": "1",
        "WEB_URL": "https://finch-web-staging.pantainos.workers.dev",
        // Custom-hostname tiers, demoable on staging: the operator tenant may
        // claim *.aviary.run; BYO adds register (no CF-for-SaaS call — no
        // CF_API_TOKEN/CF_SAAS_ZONE_ID here) and return the CNAME instruction.
        "VANITY_SUFFIXES": "aviary.run",
        "VANITY_TENANT": "user_3F74fiQzwjM6UPfl9axNpA1jgyQ",
        "BYO_CNAME_TARGET": "finchmcp.com"
      },
      "ai": { "binding": "AI" },
      // Self service-binding: the /chat tool-runner relays MCP calls back through
      // our own service path. A direct fetch to our workers.dev host is blocked
      // (error 1042); a service binding to ourselves is the supported way.
      "services": [{ "binding": "SELF", "service": "finch-staging" }],
      "durable_objects": {
        "bindings": [
          { "name": "BOX", "class_name": "BoxDO" },
          { "name": "TENANT", "class_name": "TenantDO" },
          { "name": "ROUTER", "class_name": "RouterDO" }
        ]
      },
      "unsafe": {
        "bindings": [
          {
            "name": "RELAY_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1003",
            "simple": { "limit": 600, "period": 60 }
          },
          {
            "name": "JOIN_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1004",
            "simple": { "limit": 10, "period": 60 }
          }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["ApplianceDO"] },
        { "tag": "v2", "new_sqlite_classes": ["TenantDO"] },
        { "tag": "v3", "new_sqlite_classes": ["RouterDO"] },
        { "tag": "v4", "renamed_classes": [{ "from": "ApplianceDO", "to": "BoxDO" }] }
      ]
    },

    // ---- production: real routes, no workers.dev, fail-closed tenant ----
    "production": {
      "name": "finch-prod",
      "workers_dev": false,
      "observability": { "enabled": true },
      // NO DEFAULT_TENANT and NO DEV — resolveTenant fails closed (404) for any
      // host without a registered host key.
      "vars": {
        "WEB_URL": "https://finchmcp.com",
        "VANITY_SUFFIXES": "aviary.run",
        // Production Clerk instance (pk_live/sk_live) — enables the MCP OAuth plane.
        "CLERK_ISSUER": "https://clerk.finchmcp.com",
        // Cloudflare-for-SaaS BYO provisioning: finchmcp.com zone.
        "CF_SAAS_ZONE_ID": "90ca5aa137cd55b8b174763a50641c00"
        // Set VANITY_TENANT to the single tenant allowed to claim *.aviary.run
        // (operator's user id on the PROD Clerk instance — set after first sign-up).
        // Optional BYO_CNAME_TARGET defaults to "finchmcp.com".
        // CF_API_TOKEN is a secret:
        //   wrangler secret put CF_API_TOKEN --env production
      },
      "ai": { "binding": "AI" },
      "services": [{ "binding": "SELF", "service": "finch-prod" }],
      "routes": [
        // The apex is SHARED: finch-web-prod owns finchmcp.com/* (dashboard,
        // marketing, /api/finch BFF); the hub claims only the agent/CLI paths
        // below. More-specific path routes win over web's catch-all.
        { "pattern": "finchmcp.com/join*", "zone_name": "finchmcp.com" },
        { "pattern": "finchmcp.com/refresh*", "zone_name": "finchmcp.com" },
        { "pattern": "finchmcp.com/api/cli/*", "zone_name": "finchmcp.com" },
        { "pattern": "finchmcp.com/install*", "zone_name": "finchmcp.com" },
        { "pattern": "finchmcp.com/releases/*", "zone_name": "finchmcp.com" },
        { "pattern": "*.finchmcp.com/*", "zone_name": "finchmcp.com" },
        { "pattern": "*.aviary.run/*", "zone_name": "aviary.run" }
        // BYO custom hostnames also need the catch-all route below, which
        // Cloudflare only accepts once Cloudflare-for-SaaS is enabled on the
        // finchmcp.com zone (dashboard: SSL/TLS → Custom Hostnames → Enable;
        // fallback origin = fallback.finchmcp.com, DNS record already exists).
        // Re-add once enabled:
        //   { "pattern": "*/*", "zone_name": "finchmcp.com" }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "BOX", "class_name": "BoxDO" },
          { "name": "TENANT", "class_name": "TenantDO" },
          { "name": "ROUTER", "class_name": "RouterDO" }
        ]
      },
      // unsafe is NOT inherited into named envs — repeat it per env (see CLAUDE.md).
      "unsafe": {
        "bindings": [
          {
            "name": "RELAY_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1001",
            "simple": { "limit": 600, "period": 60 }
          },
          {
            "name": "JOIN_LIMIT",
            "type": "ratelimit",
            "namespace_id": "1002",
            "simple": { "limit": 10, "period": 60 }
          }
        ]
      },
      "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["ApplianceDO"] },
        { "tag": "v2", "new_sqlite_classes": ["TenantDO"] },
        { "tag": "v3", "new_sqlite_classes": ["RouterDO"] },
        { "tag": "v4", "renamed_classes": [{ "from": "ApplianceDO", "to": "BoxDO" }] }
      ]
    }
  }
  // Secrets per env (never `secret bulk .dev.vars`):
  //   wrangler secret put FINCH_SERVICE_SECRET --env production
  //   wrangler secret put TICKET_SECRET        --env production
  //   wrangler secret put SESSION_SECRET       --env production
  // SESSION_SECRET is the SEPARATE login-wall session-cookie signer (kind:"session")
  // — keep it distinct from TICKET_SECRET so a leaked session signer can't forge a
  // join/connect/portal grant. Set it for BOTH staging and production:
  //   wrangler secret put SESSION_SECRET --env staging
  //   wrangler secret put SESSION_SECRET --env production
  // WEB_URL (the login-wall 302 target) is already a var for staging + production
  // above; dev relies on the same fallback. In dev, add SESSION_SECRET to
  // .dev.vars alongside FINCH_SERVICE_SECRET/TICKET_SECRET.
  // Deploy: wrangler deploy --env production  (or --env dev)
}
