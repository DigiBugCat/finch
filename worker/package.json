{
  "name": "finch-hub",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Finch hub — Cloudflare Worker + Durable Object relay for MCP appliances",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "latest",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "latest"
  }
}
