{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "CLOUDFLARE_ENV=production opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env production",
    "deploy:staging": "CLOUDFLARE_ENV=staging opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env staging",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "next": "^15.5.19",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "happy-dom": "^20.10.3",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": "22.x"
  }
}
